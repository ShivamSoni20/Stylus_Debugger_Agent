{
  "name": "stylus-debugger-agent",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "AI-powered audit and debug agent for Arbitrum Stylus smart contracts written in Rust.",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "tsx src/server.ts",
    "register:sepolia": "NETWORK=sepolia tsx src/register-agent.ts",
    "demo": "tsx src/cli.ts audit examples/test_contract.rs"
  },
