  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "openai": "^6.33.0",
    "tsx": "^4.16.2",
    "viem": "^2.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3"
  }
}
