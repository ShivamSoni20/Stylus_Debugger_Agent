# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Server port (optional, default 3000)
PORT=3000

# Agent registration (required for register-agent.ts)
PRIVATE_KEY=0x_your_wallet_private_key
NETWORK=sepolia
AGENT_ENDPOINT=https://your-deployed-url.com
AGENT_METADATA_URI=https://your-deployed-url.com/agent-metadata.json

# Custom RPC (optional)
# RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
